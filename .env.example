# Copy to .env and fill in your keys:
#   copy .env.example .env   (Windows)
#   cp .env.example .env       (macOS/Linux)

# Groq — LLM generation (Phase 3). Required for Groq API usage; leave blank to use template answers.
GROQ_API_KEY=
GENERATOR_PROVIDER=groq
GENERATOR_MODEL=llama-3.3-70b-versatile

# OpenAI — embeddings (Phase 2). Leave blank and set EMBEDDING_PROVIDER=deterministic for offline use.
OPENAI_API_KEY=
EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=text-embedding-3-small

# Phase 7 — Vercel frontend CORS (comma-separated origins on API server)
# API_CORS_ORIGINS=https://your-app.vercel.app,http://127.0.0.1:8000

# --- Offline / tests (no API keys) ---
# EMBEDDING_PROVIDER=deterministic
# GENERATOR_PROVIDER=template
