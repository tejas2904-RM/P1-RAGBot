{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python phases/phase7/inject_config.py > phases/phase5/frontend/config.js",
  "outputDirectory": "phases/phase5/frontend",
  "rewrites": [{ "source": "/((?!static/|config\\.js).*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/config.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ]
}
