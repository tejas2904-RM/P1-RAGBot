# Copy to .streamlit/secrets.toml for local Streamlit runs (never commit secrets.toml).
# On Streamlit Community Cloud, add the same keys in App settings → Secrets.

GROQ_API_KEY = ""
OPENAI_API_KEY = ""
EMBEDDING_PROVIDER = "openai"
GENERATOR_PROVIDER = "groq"
GENERATOR_MODEL = "llama-3.3-70b-versatile"
EMBEDDING_MODEL = "text-embedding-3-small"

# Optional — allow Vercel frontend (Phase 7)
# API_CORS_ORIGINS = "https://your-app.vercel.app,http://localhost:3000"
